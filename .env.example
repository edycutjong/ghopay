# Ghopay — Environment Variables
# Copy to .env.local and fill in values

# RPC URL for Solana connection
# Recommended: Get a free RPC URL from Helius (https://helius.dev) or Alchemy (https://www.alchemy.com/solana)
# Default fallback: https://api.mainnet-beta.solana.com (public rate-limited RPC)
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# Solana Keypair Path (for server-side / CLI usage)
# Must be an absolute path. Do not rely on `~` expansion.
# Generate one with: solana-keygen new --outfile /path/to/keypair.json
# The keypair must be funded with SOL for on-chain transactions.
# When set, enables live mode (real on-chain stealth transfers via Cloak SDK).
# When absent, the app runs in demo mode (simulated stealth addresses).
KEYPAIR_PATH=
