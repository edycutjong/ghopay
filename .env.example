# frontier-cloak Environment Variables
# Copy to .env.local and fill in values

# RPC URL for Solana connection
# Recommended: Get a free RPC URL from Helius (https://helius.dev) or Alchemy (https://www.alchemy.com/solana)
# Default fallback: https://api.mainnet-beta.solana.com (public rate-limited RPC)
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# Cloak SDK Key
# Used for private transactions via the Cloak network.
# Obtain this key from the Cloak Developer Portal: https://cloak.so/developers
CLOAK_SDK_KEY=
